// Vera — Palisade Payment Prototype
//
// Data model — post-split, post-Phase-3 shrink.
//
// Vera owns the vault + transaction + WebAuthn-registration-challenge domain.
// The card domain (Card, Program, FinancialInstitution, ChipProfile,
// IssuerProfile, SadRecord, ActivationSession, WebAuthnCredential,
// ProvisioningSession, EmbossingBatch/Template, MicrositeVersion,
// PartnerCredential, CardOpSession) lives in Palisade's repo and DB.
//
// Key decisions:
//
//   - VaultEntry is fingerprinted (HMAC-SHA256) for dedup without decrypt.
//   - VaultEncryptionKey + keyVersion on VaultEntry supports rotation for
//     PAN ciphertext.
//   - VaultAccessLog records every vault event — nothing touches PANs without
//     an audit row.
//   - Transaction status is an enum with explicit valid transitions enforced
//     in service code (src/transactions/state-machine.ts).
//   - Transaction carries denormalised card display fields (cardRef, panLast4,
//     panBin, cardholderName, vaultEntryId) stamped from a Palisade card
//     lookup at create time — post-split, Vera has no Card table to join
//     against.  Palisade is the source of truth for card state; Vera reads
//     it via the HMAC-authed /api/cards/lookup/:cardId endpoint.
//   - Provider-agnostic: Transaction stores providerName /
//     providerPaymentMethodId / providerTxnId.
//   - TokenisationProgram holds the tier rules used by pay at transaction
//     create time.  Id matches Palisade Program.id by convention; no FK
//     (different DBs).
//   - RegistrationChallenge stays on Vera despite the card-domain cutover —
//     pay's webauthn service mints + verifies registration challenges locally
//     as an anti-replay guard for the ceremony it runs.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// TokenisationProgram — Vera-side tier policy.
//
// Split from card-domain Program as part of Phase 4c of the Vera/Palisade
// separation.  Palisade owns the card Program (tier rules used to live there).
// Vera now holds its own record keyed by the same `id` (by convention), so pay
// can enforce tier rules at transaction time without reaching into Palisade.
//
// The admin UI for tier rules goes through Vera's admin backend.  Tenants with
// only the Vera (tokenisation) product still see this editor; tenants with
// only Palisade (issuance) don't touch it.
// ---------------------------------------------------------------------------

model TokenisationProgram {
  id        String   @id // conventionally matches Palisade Program.id
  name      String
  currency  String   @db.VarChar(3) // ISO 4217
  tierRules Json // TierRule[] — shape validated by Zod on write

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// Vault
// ---------------------------------------------------------------------------

model VaultEncryptionKey {
  id               String    @id @default(cuid())
  version          Int       @unique
  // Wrapped data-encryption key.  For v0 keys live in env; blob is the
  // wrapped form we would store if using KMS.  Present for rotation machinery.
  encryptedDekBlob String
  createdAt        DateTime  @default(now())
  retiredAt        DateTime?
}

model VaultEntry {
  id String @id @default(cuid())

  // Caller-supplied idempotency key for the cross-service register path
  // (Palisade → POST /api/vault/register).  Lets a retry safely return the
  // same vaultToken without creating a duplicate entry.  Unique so colliding
  // keys from distinct callers surface loudly; nullable because the internal
  // admin /store path doesn't use it.
  idempotencyKey String? @unique

  // --- plaintext metadata (safe for display, never needs decrypt) ----------
  panLast4       String
  panBin         String // first 6 of PAN
  cardholderName String
  panExpiryMonth String
  panExpiryYear  String

  // --- ciphertext ----------------------------------------------------------
  // AES-256-GCM ciphertext of the full PAN (+ CVC if present).  The payload
  // format is versioned by keyVersion.
  encryptedPan String // base64 of iv||ciphertext||tag (JSON for multi-field)
  keyVersion   Int

  // --- deterministic fingerprint for dedup (HMAC-SHA256 of normalised PAN) -
  panFingerprint String @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  retrievalTokens RetrievalToken[]
  accessLogs      VaultAccessLog[]

  @@index([panBin])
  @@index([panLast4])
}

model RetrievalToken {
  id          String   @id @default(cuid())
  // Opaque token returned to the caller.  nanoid(32).
  token       String   @unique
  // Single-use guard.
  used        Boolean  @default(false)
  // Bound to an intended amount/currency so a stolen token can't be redirected.
  amount      Int
  currency    String
  // Expiry (typically createdAt + 60s).
  expiresAt   DateTime
  // Creator (for audit).
  purpose     String
  createdByIp String?

  vaultEntryId String
  vaultEntry   VaultEntry @relation(fields: [vaultEntryId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now())
  usedAt    DateTime?

  accessLogs VaultAccessLog[]

  @@index([vaultEntryId])
  @@index([expiresAt])
}

enum VaultEventType {
  CREATE
  DUPLICATE_REJECTED
  TOKEN_MINTED
  TOKEN_CONSUMED
  PROXY_FORWARDED
  PROVIDER_TOKENISED
}

enum VaultEventResult {
  SUCCESS
  FAILURE
}

model VaultAccessLog {
  id           String           @id @default(cuid())
  eventType    VaultEventType
  result       VaultEventResult
  // Who/what initiated the event (e.g. "admin", "transaction:<rlid>",
  // "provider:stripe", "provisioning-agent").
  actor        String
  // Why (free-form, e.g. "admin store", "payment orchestration step 5").
  purpose      String
  ipAddress    String?
  userAgent    String?
  errorMessage String?

  vaultEntryId String?
  vaultEntry   VaultEntry? @relation(fields: [vaultEntryId], references: [id], onDelete: SetNull)

  retrievalTokenId String?
  retrievalToken   RetrievalToken? @relation(fields: [retrievalTokenId], references: [id], onDelete: SetNull)

  transactionId String?
  transaction   Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([eventType])
  @@index([vaultEntryId])
}

// ---------------------------------------------------------------------------
// WebAuthn
// ---------------------------------------------------------------------------
//
// Post-Phase-3 shrink: only the short-lived RegistrationChallenge lives on
// Vera.  The long-lived WebAuthnCredential records moved to Palisade
// (`services/pay/src/webauthn/webauthn.service.ts` now calls Palisade over
// HTTP for the credential list).  Pay still mints + verifies registration
// challenges locally as an anti-replay guard for the ceremony it runs.

enum CredentialKind {
  PLATFORM // Face ID / Touch ID / Windows Hello  — Tier 1/3
  CROSS_PLATFORM // NFC card tap (CTAP1 on Android)     — Tier 2
}

model RegistrationChallenge {
  id        String         @id @default(cuid())
  challenge String         @unique
  // The card the challenge was issued for.  userHandle / userLabel are
  // derived server-side from the card's opaque cuid (see beginRegistration);
  // the PICC UID never appears in any WebAuthn payload.
  cardId    String
  kind      CredentialKind
  expiresAt DateTime
  createdAt DateTime       @default(now())

  @@index([expiresAt])
}

// ---------------------------------------------------------------------------
// Transactions
// ---------------------------------------------------------------------------

enum TransactionStatus {
  PENDING
  AUTHN_STARTED
  AUTHN_COMPLETE
  ARQC_VALID
  VAULT_RETRIEVED
  STRIPE_CHARGED // provider-agnostic despite the name; kept for log clarity
  COMPLETED
  FAILED
  EXPIRED
}

enum Tier {
  TIER_1 // Low value — platform biometric (Face ID / Touch ID)
  TIER_2 // Mid value — NFC card tap (CTAP1 over NFC)
  TIER_3 // High value — platform biometric + stepped-up checks
}

model Transaction {
  id String @id @default(cuid())

  // Retrieval link ID — short, URL-safe, embedded in the QR.
  rlid String @unique

  // Palisade Card.id — a plain string now that the Card table lives in a
  // different DB.  No FK.  Pay resolves card state via the Palisade HTTP
  // client (services/pay/src/cards/palisade-client.ts).
  cardId String

  amount       Int // minor units (cents)
  currency     String @default("USD")
  merchantRef  String
  merchantName String @default("Demo Merchant")

  status     TransactionStatus @default(PENDING)
  tier       Tier
  actualTier Tier? // which ceremony actually completed

  // Credential kinds acceptable for this transaction, computed from the
  // program's tier rules + amount at create time.  Persisted so auth verify
  // enforces the same set that was advertised at /authenticate/options, even
  // if rules change mid-flight.  Non-empty by construction.
  allowedCredentialKinds CredentialKind[]

  // Server-side bound WebAuthn challenge (32 random bytes, base64url).
  challengeNonce String @unique

  // Which credential was used for this authn (set after authn_complete).
  usedCredentialId String?

  // Provider fields (renamed from Stripe-specific — see plan).
  providerName            String?
  providerPaymentMethodId String?
  providerTxnId           String?

  // OBO ARQC that we generated + self-validated, stored for audit.
  arqc    String?
  atcUsed Int?

  expiresAt     DateTime
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  completedAt   DateTime?
  failedAt      DateTime?
  failureReason String?

  // Denormalised card display fields — stamped at Transaction create time
  // from the Palisade card-lookup response.  Avoids a cross-repo join on
  // every transaction list/detail read, and keeps Transaction self-describing
  // now that the Card table is dropped from Vera.  All nullable: pre-split
  // rows carry nulls; in dev we do not backfill.
  cardRef        String?
  panLast4       String?
  panBin         String?
  cardholderName String?

  // Pointer to the local VaultEntry row — stamped from the card-lookup at
  // Transaction create time so post-auth's retrieval-token mint can skip the
  // (cross-DB) card join entirely.  Null until vault linkage, then stable
  // for the lifetime of the row.
  vaultEntryId String?

  accessLogs VaultAccessLog[]

  @@index([rlid])
  @@index([status])
  @@index([cardId])
}
