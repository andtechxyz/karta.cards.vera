# admin service — listens on manage.karta.cards
# Handles program CRUD and card admin (program assignment).
# PANs and vault keys never cross this service boundary.

NODE_ENV=development
PORT=3005

# Database
DATABASE_URL=postgresql://vera:vera@localhost:5432/vera_dev

# Origin for NDEF URL default fallback
WEBAUTHN_ORIGIN=https://manage.karta.cards
