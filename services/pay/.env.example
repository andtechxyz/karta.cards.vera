# pay service — listens on pay.karta.cards
# Handles transaction creation, WebAuthn authentication, and payment orchestration.

NODE_ENV=development
PORT=3003

# Database
DATABASE_URL=postgresql://vera:vera@localhost:5432/vera_dev

# WebAuthn (apex RP ID, multiple origins accepted)
WEBAUTHN_RP_ID=karta.cards
WEBAUTHN_ORIGINS=https://pay.karta.cards,https://tap.karta.cards,https://activation.karta.cards,https://admin.karta.cards,https://vault.karta.cards
WEBAUTHN_RP_NAME=Palisade Pay

# Vault service URL (internal — pay calls vault over HTTP)
VAULT_SERVICE_URL=http://localhost:3004

# Payment provider
PAYMENT_PROVIDER=mock
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Transaction TTL
TRANSACTION_TTL_SECONDS=300

# ARQC root seed — 32 bytes hex
VERA_ROOT_ARQC_SEED=2222222222222222222222222222222222222222222222222222222222222222
